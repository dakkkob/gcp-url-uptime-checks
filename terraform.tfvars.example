# GCP project to deploy monitoring resources into
project_id = "your-gcp-project-id"

# Notification channel ID — create one in GCP Console under Monitoring > Alerting > Notification Channels
notification_channel_id = "projects/your-gcp-project-id/notificationChannels/your-channel-id"

uptime_checks = [
  {
    hostname         = "example.com"
    path             = "/"
    check_frequency  = 300  # seconds; minimum 60
    content_matching = "Expected text on the page"
  },
  {
    hostname         = "www.example.com"
    path             = "/about"
    check_frequency  = 300
    content_matching = "About us"
  },
  # Add more sites as needed. Note: GCP free tier covers 3 checks; each additional costs ~$0.75/month.
]

alert_severity         = "WARNING"
alert_threshold        = 0.90   # alert if less than 90% of checks pass
rolling_window_seconds = 3600   # 1 hour evaluation window
alert_duration_seconds = 600    # 10-minute grace period before alert fires (prevents flapping on transient failures)
